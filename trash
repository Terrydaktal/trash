#!/bin/bash
set -euo pipefail

# Trash-per-mountpoint:
#   For each file, move it to:  <that file's filesystem mountpoint>/trash/
# Examples:
#   /home/lewis/foo.txt   -> /home/trash/foo.txt
#   /mnt/U1/bar.txt       -> /mnt/U1/trash/bar.txt
#   /etc/hosts            -> /trash/hosts            (because mountpoint is "/")
#
# Collision suffix (timestamp + ns + pid):
#   ts="$(date +%Y%m%d-%H%M%S-%N)-$$"
#
# Notes:
# - Uses mv -n (no clobber) to avoid overwrites.
# - Optimistic move first (fast path), only does extra checks on failure.
# - Broken symlinks are handled (mv moves the symlink itself).

# --- CONFIG ---
TRASH_SUBDIR="${TRASH_SUBDIR:-trash}"   # name of trash directory at mountpoint (default: "trash")

force=false
use_real_rm=false
clean_current_mountpoint=false
files_to_trash=()

orig_argv=("$@")

# --- 1) UNPACK COMBINED SHORT OPTIONS ---
unpacked_args=()
for arg in "$@"; do
    if [[ "$arg" =~ ^-[a-zA-Z0-9]{2,}$ ]]; then
        for (( i=1; i<${#arg}; i++ )); do
            unpacked_args+=("-${arg:$i:1}")
        done
    else
        unpacked_args+=("$arg")
    fi
done
set -- "${unpacked_args[@]}"

# --- 2) PARSE ARGUMENTS (robust) ---
while [ $# -gt 0 ]; do
    case "$1" in
        --help|--version)
            use_real_rm=true
            break
            ;;
        -f|--force)
            force=true
            shift
            ;;
        --clean)
            clean_current_mountpoint=true
            shift
            ;;
        -i|-v|-I|--interactive|--verbose|-r|-R|--recursive)
            # accepted but ignored; behaviour is "trash", not full rm emulation
            shift
            ;;
        --)
            shift
            # everything after -- is a path
            while [ $# -gt 0 ]; do
                files_to_trash+=("$1")
                shift
            done
            ;;
        -*)
            # unknown option => fall back to real rm for correctness
            use_real_rm=true
            break
            ;;
        *)
            files_to_trash+=("$1")
            shift
            ;;
    esac
done

if [ "$clean_current_mountpoint" = true ] && [ ${#files_to_trash[@]} -gt 0 ]; then
    echo "rm: cannot use --clean with file operands" >&2
    exit 2
fi

# If passing through, do it with the original arguments
if [ "$use_real_rm" = true ] || { [ "$clean_current_mountpoint" = false ] && [ ${#files_to_trash[@]} -eq 0 ]; }; then
    exec /bin/rm "${orig_argv[@]}"
fi

# --- 2) MASTER FOLDER GENERATION ---
# Walk up the Linux process tree to find the execution chain
process_chain=()
curr_pid="$PPID"
while [ "$curr_pid" -gt 1 ]; do
    name=$(cat "/proc/$curr_pid/comm" 2>/dev/null || true)
    if [ -n "$name" ]; then
        process_chain+=("$name")
    else
        break
    fi
    next_pid=$(awk '{print $4}' "/proc/$curr_pid/stat" 2>/dev/null || true)
    if [ -n "$next_pid" ] && [ "$next_pid" -ne "$curr_pid" ]; then
        curr_pid="$next_pid"
    else
        break
    fi
done

parent_app="unknown"
if [ ${#process_chain[@]} -gt 0 ]; then
    parent_app="$(echo "${process_chain[0]}" | sed 's/[^a-zA-Z0-9._-]/_/g')"
fi

# Generate a unique, timestamped folder name using prefixes of the first few
# targets and a sanitized parent app tag at the front.
names=()
for item in "${files_to_trash[@]:0:2}"; do
    # Get basename and replace special/unsafe characters with underscores
    clean_name="$(basename -- "$item" | sed 's/[^a-zA-Z0-9._-]/_/g')"
    if [ -n "$clean_name" ]; then
        names+=("$clean_name")
    fi
done

prefix=""
if [ ${#names[@]} -gt 0 ]; then
    # Join the names with plus signs and add a trailing dash
    prefix="$(IFS=+ ; echo "${names[*]}")-"
fi

RUN_DIR_NAME="(${parent_app})${prefix}$(date +%Y-%m-%d_%H-%M-%S)-pid-$$"

# --- PRE-COMPUTE METADATA JSON CONTENT ---
escape_json_string() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    str="${str//$'\n'/\\n}"
    str="${str//$'\r'/\\r}"
    str="${str//$'\t'/\\t}"
    echo -n "$str"
}

cmd_name="rm"

cmd_string="$cmd_name"
if [ ${#orig_argv[@]} -gt 0 ]; then
    escaped_args=$(printf "%q " "${orig_argv[@]}")
    escaped_args="${escaped_args% }"
    cmd_string="$cmd_name $escaped_args"
fi

invoked_by=""
if [ ${#process_chain[@]} -gt 0 ]; then
    invoked_by="${process_chain[0]}"
    for (( i=1; i<${#process_chain[@]}; i++ )); do
        invoked_by="$invoked_by <- ${process_chain[i]}"
    done
fi

METADATA_JSON_CONTENT="$(cat <<EOF
{
  "command": "$(escape_json_string "$cmd_string")",
  "cwd": "$(escape_json_string "$PWD")",
  "invoked_by": "$(escape_json_string "$invoked_by")"
}
EOF
)"

# --- 3) TRASH IMPLEMENTATION ---
# Cache which mountpoints we've already ensured have a trash dir (speed).
declare -A ensured_trash_dir=()

had_error=0

get_mountpoint() {
    # Uses lstat (does NOT follow symlinks), so broken symlinks still work.
    # Prints mountpoint (e.g. "/", "/home", "/mnt/U1")
    stat -c %m -- "$1"
}

trash_dir_for_mountpoint() {
    # $1 = mountpoint
    local mp="$1"
    if [ "$mp" = "/" ]; then
        echo "/$TRASH_SUBDIR"
    else
        echo "${mp%/}/$TRASH_SUBDIR"
    fi
}

ensure_trash_dir() {
    # $1 = mountpoint
    local mp="$1"
    local key="$mp"

    if [[ -n "${ensured_trash_dir[$key]:-}" ]]; then
        return 0
    fi

    local dir
    dir="$(trash_dir_for_mountpoint "$mp")"

    # Create the run-specific subdirectory (master folder)
    if ! mkdir -p -- "$dir/$RUN_DIR_NAME" 2>/dev/null; then
        return 1
    fi

    # Write the metadata JSON file containing the command and CWD
    echo "$METADATA_JSON_CONTENT" > "$dir/$RUN_DIR_NAME/metadata.json" 2>/dev/null || true

    ensured_trash_dir[$key]="$dir/$RUN_DIR_NAME"
    return 0
}

clean_current_trash() {
    local mp
    if ! mp="$(get_mountpoint "." 2>/dev/null)"; then
        if [ "$force" = false ]; then
            echo "rm: cannot clean trash: failed to determine mountpoint for '$PWD'" >&2
        fi
        return 1
    fi

    local dir
    dir="$(trash_dir_for_mountpoint "$mp")"
    if [ ! -d "$dir" ]; then
        return 0
    fi

    # Require confirmation if stdout/stdin is a terminal and --force is not specified
    if [ "$force" = false ] && [ -t 0 ] && [ -t 1 ]; then
        echo "WARNING: This will permanently empty the trash at '$dir'." >&2
        echo -n "To confirm, please type the full path of the trash directory: " >&2
        local response
        if ! read -r response; then
            echo -e "\nError: Failed to read confirmation. Aborting." >&2
            return 1
        fi
        if [ "$response" != "$dir" ]; then
            echo "Confirmation failed (input did not match '$dir'). Aborting." >&2
            return 1
        fi
    fi

    # find -delete handles hidden entries and does not require shell globs.
    if ! find "$dir" -mindepth 1 -delete 2>/dev/null; then
        if [ "$force" = false ]; then
            echo "rm: cannot clean trash at '$dir': Permission denied or deletion failed" >&2
        fi
        return 1
    fi

    return 0
}

trash_one() {
    local file="$1"

    # rm -f treats a missing operand as success.
    if [ ! -e "$file" ] && [ ! -L "$file" ]; then
        if [ "$force" = false ]; then
            echo "rm: cannot remove '$file': No such file or directory" >&2
            return 1
        fi
        return 0
    fi

    # Determine mountpoint (only on the slow-ish path where we actually do work)
    local mp
    if ! mp="$(get_mountpoint "$file" 2>/dev/null)"; then
        # Source exists, so this is some other failure (permissions, odd FS state, etc.).
        if [ "$force" = false ]; then
            echo "rm: cannot remove '$file': failed to determine mountpoint" >&2
        fi
        return 1
    fi

    if ! ensure_trash_dir "$mp"; then
        # Must trash to mountpoint/trash as requested; if we can't create/use it, error.
        if [ "$force" = false ]; then
            local dir
            if [ "$mp" = "/" ]; then dir="/$TRASH_SUBDIR"; else dir="${mp%/}/$TRASH_SUBDIR"; fi
            echo "rm: cannot move '$file' to '$dir': Permission denied or cannot create trash directory" >&2
        fi
        return 1
    fi

    local trash_dir="${ensured_trash_dir[$mp]}"
    local base_name
    base_name="$(basename -- "$file")"

    # Fast path: try move to plain name without overwriting
    local dest="$trash_dir/$base_name"
    if mv -n -- "$file" "$dest" 2>/dev/null; then
        return 0
    fi

    # On failure, decide what happened:
    #  - If destination exists -> collision, retry with timestamp suffix
    #  - If source missing -> rm-like ENOENT
    #  - Else -> some other error
    if [ -e "$dest" ] || [ -L "$dest" ]; then
        # Collision path: timestamp suffix (ns) + pid, plus bounded retries
        for _ in {1..10}; do
            local ts
            ts="$(date +%Y%m%d-%H%M%S-%N)-$$"
            local dest2="$trash_dir/${base_name}-${ts}"
            if mv -n -- "$file" "$dest2" 2>/dev/null; then
                return 0
            fi
            # If source disappeared mid-flight, stop early
            if [ ! -e "$file" ] && [ ! -L "$file" ]; then
                break
            fi
        done
        if [ "$force" = false ]; then
            echo "rm: cannot remove '$file': failed to resolve name collision in trash" >&2
        fi
        return 1
    fi

    # Not a collision. Check if source exists (slow path only).
    if [ ! -e "$file" ] && [ ! -L "$file" ]; then
        if [ "$force" = false ]; then
            echo "rm: cannot remove '$file': No such file or directory" >&2
            return 1
        fi
        return 0
    fi

    # Some other mv failure (permissions, immutable, etc.)
    if [ "$force" = false ]; then
        echo "rm: cannot remove '$file': move to trash failed" >&2
    fi
    return 1
}

if [ "$clean_current_mountpoint" = true ]; then
    if clean_current_trash; then
        exit 0
    fi
    exit 1
fi

for f in "${files_to_trash[@]}"; do
    if ! trash_one "$f"; then
        had_error=1
        # We already match rm -f for missing paths; continue across operands either way.
    fi
done

exit "$had_error"
